# FlowSteer executor backend configuration template.
# Copy this file to config/aflow_llm.yaml and edit the endpoint/key.
# config/aflow_llm.yaml is ignored by git to avoid leaking credentials.

models:
  gpt-oss-120b:
    api_type: openai
    base_url: http://127.0.0.1:8004/v1
    api_key: EMPTY
    model_name: gpt-oss-120b
    temperature: 0
    top_p: 1
    max_tokens: 4096

  gpt-4o-mini:
    api_type: openai
    base_url: https://api.openai.com/v1
    api_key: ${OPENAI_API_KEY}
    model_name: gpt-4o-mini
    temperature: 0
    top_p: 1
    max_tokens: 4096
